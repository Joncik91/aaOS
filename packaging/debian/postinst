#!/bin/sh
set -e

case "$1" in
  configure)
    # Ensure the aaos system group exists. Operators join this group
    # (`sudo adduser $USER aaos`) to get access to /run/agentd/agentd.sock.
    # Creating it separately from the user makes the intent explicit:
    # the group is a public interface; the user is an implementation detail.
    if ! getent group aaos >/dev/null; then
      addgroup --system aaos
    fi

    # Ensure the aaos system user exists. `--ingroup aaos` reuses the
    # group we created above instead of synthesizing a new group.
    # State dirs (/var/lib/aaos, /run/agentd) come from the systemd unit's
    # StateDirectory= / RuntimeDirectory= at service start.
    if ! getent passwd aaos >/dev/null; then
      adduser --system --ingroup aaos --home /var/lib/aaos \
              --no-create-home --shell /usr/sbin/nologin aaos
    fi

    # Ensure the configuration directory exists. The daemon reads
    # /etc/aaos/mcp-servers.yaml (MCP integration) from here at startup;
    # the directory must exist even when the file is absent so operators
    # can drop config files in place without restarting the package.
    mkdir -p /etc/aaos

    # Ensure the per-run workspace root exists. systemd's
    # StateDirectory=aaos creates /var/lib/aaos/ 0750 aaos:aaos at
    # service start, but the workspace/ subdirectory is only created
    # lazily by the runtime on the first submit. After `apt purge`
    # removes /var/lib/aaos entirely, the next install's first submit
    # would race to create it. Creating it here (idempotent) keeps
    # state identical after purge+install as after a fresh install.
    mkdir -p /var/lib/aaos/workspace
    chown -R aaos:aaos /var/lib/aaos 2>/dev/null || true
    chmod 0750 /var/lib/aaos /var/lib/aaos/workspace 2>/dev/null || true

    # Ensure /var/log/agentd exists with aaos-writable perms. Used as
    # the default target for AAOS_NAMESPACED_CHILD_DEBUG and
    # AAOS_NAMESPACED_WORKER_STDERR diagnostic files, which the child
    # process (running as aaos) needs to write from inside its mount
    # namespace. systemd's PrivateTmp=true isolates /tmp from the host
    # so /tmp-based debug paths aren't visible post-hoc; /var/log is
    # unaffected.
    mkdir -p /var/log/agentd
    chown aaos:aaos /var/log/agentd 2>/dev/null || true
    chmod 0750 /var/log/agentd 2>/dev/null || true

    # Lock down the env file (LLM API keys live here). systemd reads
    # EnvironmentFile= as root before de-privileging to User=aaos, so
    # 0600 root:root is enough for the service to start while denying
    # read access to every agent process, operator in the `aaos` group,
    # and child agent spawned by the daemon. If the file exists already
    # with a looser mode (common after an in-place upgrade from an
    # earlier package version), tighten it now.
    if [ -e /etc/default/aaos ]; then
      chown root:root /etc/default/aaos || true
      chmod 0600 /etc/default/aaos || true
    fi

    # Generate /etc/default/aaos.example with kernel-probe-sensitive
    # defaults. Operators copy this to /etc/default/aaos (the env file
    # systemd reads) after filling in their LLM API key, or let
    # `agentd configure` do it for them.
    #
    # Probes:
    #   * Landlock — /sys/kernel/security/lsm lists the active LSM stack.
    #     Look for "landlock" there.  Debian 13's stock kernel (6.12+)
    #     ships it enabled; a custom kernel might not.
    #   * Unprivileged user namespaces — either kernel.unprivileged_userns_clone=1,
    #     or the sysctl no longer exists (newer kernels drop the knob
    #     and it's unconditionally on).  Debian 13 has both.
    #
    # When both are available, the .example enables the namespaced
    # backend and worker-side tool confinement.  Otherwise it falls
    # back to the in-process backend with an explanation comment
    # pointing at the failing probe.
    landlock_ok=0
    userns_ok=0
    if [ -r /sys/kernel/security/lsm ]; then
      case ",$(cat /sys/kernel/security/lsm 2>/dev/null)," in
        *,landlock,*) landlock_ok=1 ;;
      esac
    fi
    if [ -r /proc/sys/kernel/unprivileged_userns_clone ]; then
      [ "$(cat /proc/sys/kernel/unprivileged_userns_clone 2>/dev/null)" = "1" ] && userns_ok=1
    else
      # Newer kernels no longer expose the sysctl; userns is on unconditionally.
      # AppArmor policies can still restrict it, but the sysctl's absence
      # alone is not a negative signal.
      userns_ok=1
    fi

    confine_comment=""
    if [ "$landlock_ok" = "1" ] && [ "$userns_ok" = "1" ]; then
      backend_line="AAOS_DEFAULT_BACKEND=namespaced"
      confine_line="AAOS_CONFINE_SUBTASKS=1"
      confine_comment="# Kernel probes passed (Landlock + userns both available)."
    else
      backend_line="# AAOS_DEFAULT_BACKEND=namespaced  # disabled: kernel probe failed"
      confine_line="# AAOS_CONFINE_SUBTASKS=1          # disabled: kernel probe failed"
      confine_comment="# Kernel probes failed (landlock_ok=$landlock_ok userns_ok=$userns_ok)."
      confine_comment="$confine_comment
# Check Debian 13+ kernel with CONFIG_SECURITY_LANDLOCK=y and enabled via lsm= boot param."
    fi

    cat > /etc/default/aaos.example <<EOF
# aaOS daemon environment — template.
#
# Copy to /etc/default/aaos and fill in an LLM API key:
#   sudo cp /etc/default/aaos.example /etc/default/aaos
#   sudoedit /etc/default/aaos
#   sudo chmod 0600 /etc/default/aaos
#   sudo systemctl restart agentd
#
# Or let \`agentd configure\` do it for you interactively.

# ---------- LLM provider (required — daemon runs but agents cannot run without this) ----------
# Prefer DeepSeek (cheap + fast); Anthropic is the fallback.
# DEEPSEEK_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ---------- Runtime backend ----------
$confine_comment
$backend_line
$confine_line

# ---------- Inference scheduling ----------
# AAOS_MAX_CONCURRENT_INFERENCE=3

# ---------- Skills catalog ----------
# Bundled 21 skills live at /usr/share/aaos/skills/ and are auto-discovered.
# Append custom roots colon-separated (shadow-by-name wins last):
# AAOS_SKILLS_DIR=/srv/team-skills:/opt/extra-skills

# ---------- Memory persistence ----------
# AAOS_MEMORY_DB=/var/lib/aaos/memory.db

# ---------- Workspace GC ----------
# AAOS_WORKSPACE_TTL_DAYS=7
EOF
    chmod 0644 /etc/default/aaos.example

    # Enable + start the daemon on fresh installs. When `maintainer-scripts`
    # is set in [package.metadata.deb], cargo-deb copies our scripts
    # verbatim and does NOT append its own `systemd-units` directives —
    # even with `systemd-units = { enable = true, start = true }` set.
    # So we do the systemd wiring manually here. `|| true` keeps a missing
    # DEEPSEEK_API_KEY at /etc/default/aaos from failing the package
    # install; operators see `systemctl status agentd` after install if the
    # start failed.
    if [ -d /run/systemd/system ]; then
      systemctl --system daemon-reload >/dev/null 2>&1 || true
      if command -v deb-systemd-helper >/dev/null 2>&1; then
        deb-systemd-helper unmask agentd.service >/dev/null 2>&1 || true
        deb-systemd-helper enable agentd.service >/dev/null 2>&1 || true
      else
        systemctl enable agentd.service >/dev/null 2>&1 || true
      fi
      systemctl start agentd.service >/dev/null 2>&1 || true
    fi
    ;;
esac

#DEBHELPER#

exit 0
