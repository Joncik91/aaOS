#!/bin/sh
set -e

case "$1" in
  configure)
    # Ensure the aaos system group exists. Operators join this group
    # (`sudo adduser $USER aaos`) to get access to /run/agentd/agentd.sock.
    # Creating it separately from the user makes the intent explicit:
    # the group is a public interface; the user is an implementation detail.
    if ! getent group aaos >/dev/null; then
      addgroup --system aaos
    fi

    # Ensure the aaos system user exists. `--ingroup aaos` reuses the
    # group we created above instead of synthesizing a new group.
    # State dirs (/var/lib/aaos, /run/agentd) come from the systemd unit's
    # StateDirectory= / RuntimeDirectory= at service start.
    if ! getent passwd aaos >/dev/null; then
      adduser --system --ingroup aaos --home /var/lib/aaos \
              --no-create-home --shell /usr/sbin/nologin aaos
    fi

    # Ensure the configuration directory exists. The daemon reads
    # /etc/aaos/mcp-servers.yaml (MCP integration) from here at startup;
    # the directory must exist even when the file is absent so operators
    # can drop config files in place without restarting the package.
    mkdir -p /etc/aaos

    # Lock down the env file (LLM API keys live here). systemd reads
    # EnvironmentFile= as root before de-privileging to User=aaos, so
    # 0600 root:root is enough for the service to start while denying
    # read access to every agent process, operator in the `aaos` group,
    # and child agent spawned by the daemon. If the file exists already
    # with a looser mode (common after an in-place upgrade from an
    # earlier package version), tighten it now.
    if [ -e /etc/default/aaos ]; then
      chown root:root /etc/default/aaos || true
      chmod 0600 /etc/default/aaos || true
    fi

    # Enable + start the daemon on fresh installs. When `maintainer-scripts`
    # is set in [package.metadata.deb], cargo-deb copies our scripts
    # verbatim and does NOT append its own `systemd-units` directives —
    # even with `systemd-units = { enable = true, start = true }` set.
    # So we do the systemd wiring manually here. `|| true` keeps a missing
    # DEEPSEEK_API_KEY at /etc/default/aaos from failing the package
    # install; operators see `systemctl status agentd` after install if the
    # start failed.
    if [ -d /run/systemd/system ]; then
      systemctl --system daemon-reload >/dev/null 2>&1 || true
      if command -v deb-systemd-helper >/dev/null 2>&1; then
        deb-systemd-helper unmask agentd.service >/dev/null 2>&1 || true
        deb-systemd-helper enable agentd.service >/dev/null 2>&1 || true
      else
        systemctl enable agentd.service >/dev/null 2>&1 || true
      fi
      systemctl start agentd.service >/dev/null 2>&1 || true
    fi
    ;;
esac

#DEBHELPER#

exit 0
