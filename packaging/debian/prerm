#!/bin/sh
set -e

case "$1" in
  remove|upgrade|deconfigure)
    # Stop the daemon before the binary is removed. Same reason we had to
    # add the enable/start manually in postinst — cargo-deb's systemd-units
    # auto-generation is skipped when maintainer-scripts is set, so we
    # handle stop ourselves here. `|| true` tolerates the "already stopped"
    # path.
    if [ -d /run/systemd/system ]; then
      if command -v deb-systemd-invoke >/dev/null 2>&1; then
        deb-systemd-invoke stop agentd.service >/dev/null 2>&1 || true
      else
        systemctl stop agentd.service >/dev/null 2>&1 || true
      fi
    fi
    ;;
esac

#DEBHELPER#

exit 0
