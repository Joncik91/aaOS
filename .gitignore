.DS_Store
docs/superpowers/
docs/product-brief.md
# Phase plans + designs — working artifacts for Claude / Qwen / Copilot
# cycles. Glob so new phases (F-b/3, F-b/4, G, ...) don't have to
# re-edit this file. The code, reflection entries, and commit messages
# are the durable public record; plans are iterated drafts.
docs/phase-*-plan.md
docs/phase-*-design.md
docs/phase-*-qa-plan.md
CLAUDE.md

# Private security-gaps ledger. Public docs publish shipped fixes and
# contracts; gap/exploit-path detail lives local only so attackers
# don't get a prioritized shopping list from the repo.
docs/security-gaps.md

# Runtime persistent memory (SQLite + WAL). Survives restarts when
# AAOS_PERSISTENT_MEMORY=1 is set; otherwise re-created empty per run.
/memory/

# Agent output from runs. Each run's workspace files land here; evidence
# of what happened lives in docs/reflection/, not in per-run artifact
# trees in the repo.
/output/

# Implementation plans — working artifacts for Claude/Qwen/Copilot cycles.
# Kept out of git so plan iterations don't clutter history; the code plus
# commit messages plus docs are the durable record.
/plans/
__pycache__/
packaging/debian/changelog.Debian.gz
packaging/agentd.1.gz
