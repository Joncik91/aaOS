{
  "execution_trace_schema": {
    "description": "Schema for storing execution traces in episodic memory",
    "type": "object",
    "properties": {
      "trace_id": {
        "type": "string",
        "description": "Unique identifier for this trace"
      },
      "goal": {
        "type": "string",
        "description": "The goal or objective being pursued"
      },
      "goal_hash": {
        "type": "string",
        "description": "Hash of goal for quick comparison"
      },
      "plan": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "description": "Action performed"
            },
            "tool": {
              "type": "string",
              "description": "Tool used (if applicable)"
            },
            "parameters": {
              "type": "object",
              "description": "Parameters passed to the action"
            },
            "result": {
              "type": "object",
              "description": "Result of the action"
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "When the action was performed"
            },
            "duration_ms": {
              "type": "number",
              "description": "How long the action took in milliseconds"
            }
          },
          "required": ["action", "timestamp"]
        }
      },
      "outcome": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Whether the goal was achieved"
          },
          "partial_success": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Degree of success (0-1)"
          },
          "error": {
            "type": "string",
            "description": "Error message if failed"
          },
          "cost_units": {
            "type": "number",
            "description": "Estimated cost units (API calls, compute, etc.)"
          },
          "total_duration_ms": {
            "type": "number",
            "description": "Total execution time in milliseconds"
          }
        },
        "required": ["success"]
      },
      "metadata": {
        "type": "object",
        "properties": {
          "agent_version": {
            "type": "string",
            "description": "Version of agent that executed this"
          },
          "environment": {
            "type": "string",
            "description": "Execution environment context"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Tags for categorization"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "When trace was recorded"
          }
        }
      }
    },
    "required": ["trace_id", "goal", "plan", "outcome"]
  },
  
  "pattern_template_schema": {
    "description": "Schema for storing reusable behavioral patterns",
    "type": "object",
    "properties": {
      "pattern_id": {
        "type": "string",
        "description": "Unique identifier for this pattern"
      },
      "name": {
        "type": "string",
        "description": "Human-readable pattern name"
      },
      "description": {
        "type": "string",
        "description": "Pattern description and use cases"
      },
      "goal_pattern": {
        "type": "string",
        "description": "Pattern of goals this applies to (regex or semantic pattern)"
      },
      "goal_embeddings": {
        "type": "array",
        "items": {
          "type": "number"
        },
        "description": "Vector embedding of typical goals for similarity matching"
      },
      "strategy": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "step_type": {
              "type": "string",
              "enum": ["action", "decision", "checkpoint", "parallel"],
              "description": "Type of step in the pattern"
            },
            "action_template": {
              "type": "string",
              "description": "Template for action (can include variables like {goal}, {context})"
            },
            "tool_preference": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Preferred tools for this step"
            },
            "conditions": {
              "type": "object",
              "description": "Conditions for applying this step"
            },
            "fallbacks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "condition": {
                    "type": "string",
                    "description": "Condition triggering fallback"
                  },
                  "alternative": {
                    "type": "string",
                    "description": "Alternative action"
                  }
                }
              }
            }
          }
        }
      },
      "metrics": {
        "type": "object",
        "properties": {
          "success_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Historical success rate (0-1)"
          },
          "average_cost": {
            "type": "number",
            "description": "Average cost units per execution"
          },
          "average_duration_ms": {
            "type": "number",
            "description": "Average duration in milliseconds"
          },
          "execution_count": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of times pattern has been used"
          },
          "last_used": {
            "type": "string",
            "format": "date-time",
            "description": "When pattern was last used"
          },
          "adaptation_rate": {
            "type": "number",
            "description": "How often pattern is adapted (0-1)"
          }
        }
      },
      "constraints": {
        "type": "object",
        "properties": {
          "required_capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Required capabilities for this pattern"
          },
          "environment_requirements": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Required environment features"
          },
          "complexity_limit": {
            "type": "string",
            "enum": ["simple", "medium", "complex"],
            "description": "Maximum complexity this pattern handles"
          }
        }
      },
      "metadata": {
        "type": "object",
        "properties": {
          "created_from": {
            "type": "string",
            "description": "Trace ID this pattern was created from"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "When pattern was created"
          },
          "last_updated": {
            "type": "string",
            "format": "date-time",
            "description": "When pattern was last updated"
          },
          "version": {
            "type": "string",
            "description": "Pattern version"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Categorization tags"
          }
        }
      }
    },
    "required": ["pattern_id", "name", "goal_pattern", "strategy", "metrics"]
  },
  
  "pattern_match_schema": {
    "description": "Schema for pattern matching results",
    "type": "object",
    "properties": {
      "goal": {
        "type": "string",
        "description": "Goal being matched"
      },
      "matched_patterns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "pattern_id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "similarity_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "expected_success_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "expected_cost": {
              "type": "number"
            },
            "adaptation_required": {
              "type": "boolean"
            },
            "adaptation_points": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "selected_pattern": {
        "type": "object",
        "description": "The selected pattern after scoring"
      },
      "selection_reason": {
        "type": "string",
        "description": "Why this pattern was selected"
      },
      "timestamp": {
        "type": "string",
        "format": "date-time"
      }
    }
  }
}